{
  "intents": {
    "crawl": "crawlio.start_crawl",
    "analyze": "crawlio.analyze_page",
    "browse": "playwright.execute"
  },
  "elicitation": {
    "mode": "auto"
  },
  "mcpServers": {
    "mentu": {
      "command": "npx",
      "args": ["-y", "mentu-mcp"],
      "env": {
        "MENTU_API_KEY": "your_api_key"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "crawlio": {
      "command": "npx",
      "args": ["-y", "crawlio-mcp"]
    }
  }
}
